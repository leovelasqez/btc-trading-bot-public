# ============================================
# BTC Trading Bot — Environment Variables
# Copia este archivo como .env y llena los valores
# ============================================

# Binance Futures API
# Crear en: https://www.binance.com/en/my/settings/api-management
# Para testnet: https://testnet.binancefuture.com/
BINANCE_API_KEY=your-api-key
BINANCE_API_SECRET=your-api-secret
BINANCE_TESTNET=true

# Gemini AI API
# Crear en: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Telegram Bot
# Crear bot con @BotFather, obtener chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Supabase
# Dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Bot Configuration ───
TRADING_MODE=semi-auto
LEVERAGE=5
MAX_POSITION_PCT=100
MAX_DAILY_LOSS_PCT=5
MAX_TRADES_PER_DAY=10
ANALYSIS_INTERVAL_MINUTES=15
CONFIDENCE_THRESHOLD=70
